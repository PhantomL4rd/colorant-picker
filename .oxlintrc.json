{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "es2024": true,
    "node": true
  },
  "globals": {
    "$state": "readonly",
    "$derived": "readonly",
    "$effect": "readonly",
    "$props": "readonly",
    "$bindable": "readonly",
    "$inspect": "readonly",
    "$host": "readonly"
  },
  "rules": {
    "typescript/no-non-null-assertion": "off",
    "typescript/no-explicit-any": "off",
    "no-param-reassign": "off",
    "no-unused-vars": "off",
    "typescript/no-unused-vars": "off",
    "no-empty-pattern": "off",
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["**/*.svelte", "**/*.svelte.ts"],
      "rules": {
        "prefer-const": "off",
        "no-cond-assign": "off",
        "no-self-assign": "off"
      }
    },
    {
      "files": ["**/stores/**/*.ts"],
      "rules": {
        "no-cond-assign": "off"
      }
    }
  ],
  "ignorePatterns": [
    "build/**",
    ".svelte-kit/**",
    "node_modules/**",
    "static/**",
    "src/app.css",
    ".wrangler/**",
    ".wrangler-persist/**",
    "src/routes/+page.svelte",
    "src/routes/about/+page.svelte"
  ]
}

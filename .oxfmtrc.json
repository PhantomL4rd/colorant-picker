{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "svelte": true,
  "ignorePatterns": [
    "build/**",
    ".svelte-kit/**",
    "node_modules/**",
    "static/**",
    "src/app.css",
    ".wrangler/**",
    ".wrangler-persist/**",
    "package-lock.json",
    "bun.lock",
    "bun.lockb"
  ]
}
